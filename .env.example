WORDPRESS_COM_SITE=portalentrelinhasdotcomdotbr.wordpress.com
# Opcional no plano free publico; use token real apenas se o CMS exigir autenticacao.
WORDPRESS_COM_ACCESS_TOKEN=
WORDPRESS_COM_API_BASE=https://public-api.wordpress.com/wp/v2/sites
WORDPRESS_REVALIDATE_SECONDS=60
WORDPRESS_TIMEOUT_MS=10000
WHATSAPP_ADMIN_NUMBER=5577999999999
REVALIDATE_WEBHOOK_SECRET=coloque_um_segredo_forte
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com
AD_SYSTEM_ENABLED=true
# Optional advanced config:
# AD_CAMPAIGNS_JSON=[{"id":"campanha-1","advertiser":"Marca X","title":"Oferta especial","description":"Descricao curta","targetUrl":"https://example.com","slots":["sidebar-home","rail-right-desktop"],"priority":10,"active":true}]
ADS_CACHE_SECONDS=60

# Admin painel de anuncios (obrigatorio para CRUD sem editar codigo)
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=troque_essa_senha
ADMIN_SESSION_SECRET=troque_por_uma_chave_longa
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=900
ADMIN_LOGIN_LOCK_SECONDS=1200
ADMIN_IP_ALLOWLIST_ENABLED=false
# Ex.: ADMIN_ALLOWED_IPS=177.23.10.5,177.23.10.0/24,127.0.0.1,::1
ADMIN_ALLOWED_IPS=

# Supabase para persistencia de anuncios
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_service_role_key_aqui
SUPABASE_ADS_TABLE=ad_campaigns
SUPABASE_ADS_AUDIT_TABLE=ad_campaign_audit_logs
SUPABASE_ADS_STORAGE_BUCKET=ads-images
SUPABASE_TIMEOUT_MS=8000
ADS_IMAGE_MAX_BYTES=5242880

# Legacy public mode (optional fallback)
# WORDPRESS_API_URL=https://public-api.wordpress.com/wp/v2/sites/portalentrelinhasdotcomdotbr.wordpress.com

